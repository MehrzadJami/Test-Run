# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
#   cp .env.example .env

# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Docker Compose default: postgresql://postgres:password@localhost:5432/chemai
# Replit:                 set automatically when the PostgreSQL integration is added
DATABASE_URL=postgresql://postgres:password@localhost:5432/chemai

# Secret used to sign HTTP sessions (reserved — required when M15 Auth is added).
# Generate a strong value with:  openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-secret

# ─── Optional AI providers ────────────────────────────────────────────────────
# Leave blank (or omit) to run in demo/mock mode — no real AI calls are made.
# The app is fully functional without these; the demo chemostat model loads from
# the database seed and mock extractions return deterministic results.

OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Runtime ──────────────────────────────────────────────────────────────────

# "development" or "production"
NODE_ENV=development

# Port for the API server.
# Replit injects this automatically per-service.
# For local dev outside Replit, set to any free port.
PORT=8080

# Base path prefix for the Vite frontend.
# Replit injects this automatically. For local dev set "/".
BASE_PATH=/

# Frontend dev proxy target used by Vite to forward /api requests locally.
# Keep this as the API server URL in local mode.
VITE_API_PROXY_TARGET=http://localhost:8080
VITE_FEATURE_AUTH=false
VITE_FEATURE_MULTISOURCE=false
VITE_FEATURE_INLINE_EDITING=true
VITE_FEATURE_AUDIT_TRAIL=true
VITE_FEATURE_PDF_UPLOAD=true
VITE_FEATURE_NOTEBOOK_EXPORT=true
VITE_FEATURE_REAL_AI=false
VITE_FEATURE_EXPERIMENTAL_FITTING=false

# Replit-only values (optional for local mode).
REPL_ID=
ISSUER_URL=https://replit.com/oidc
