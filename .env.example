# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
#   cp .env.example .env

# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Docker Compose default: postgresql://postgres:password@localhost:5432/chemengai
# Replit:                 set automatically when the PostgreSQL integration is added
DATABASE_URL=postgresql://postgres:password@localhost:5432/chemengai

# Secret used to sign HTTP sessions (reserved — required when M15 Auth is added).
# Generate a strong value with:  openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-secret

# ─── Optional AI providers ────────────────────────────────────────────────────
# Leave blank (or omit) to run in demo/mock mode — no real AI calls are made.
# The app is fully functional without these; the demo chemostat model loads from
# the database seed and mock extractions return deterministic results.

OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Runtime ──────────────────────────────────────────────────────────────────

# "development" or "production"
NODE_ENV=development

# Port for the API server.
# Replit injects this automatically per-service.
# For local dev outside Replit, set to any free port.
PORT=8080

# Host port for Docker Compose PostgreSQL.
# Change this if another local Postgres already uses 5432.
POSTGRES_PORT=5432

# Port for the local Vite frontend dev server.
# Keep this different from PORT so API and frontend can run together.
FRONTEND_PORT=5173

# Where the local Vite dev server proxies /api requests.
VITE_API_TARGET=http://localhost:8080

# Base path prefix for the Vite frontend.
# Replit injects this automatically.
# For local dev outside Replit, set to "/".
BASE_PATH=/
